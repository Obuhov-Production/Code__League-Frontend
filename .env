VITE_APP_NAME=Code League
VITE_FRONTEND_PORT=3000

# Vite proxy prefix
VITE_API_BASE_URL=/api

# Backend URL (OAuth, direct calls)
VITE_BACKEND_URL=http://localhost:3001

# Contact method: Discord
CONTACT_METHOD=Discord
WEBHOOK_URL=https://discord.com/api/webhooks/11111111111111111111/XXXXXXXXXXXXXXXXXXXXXXXXXX

# false = без бекенду, dashboard/login одразу відкриваються
# Логіка для без перевірки вхід (віхд можна виконати з викнлюченим бекендом) перекине в dashboard
VITE_CHECK_BACKEND=true

# false = статичні цифри; true = тягне з /api/stats (536→500+, 556→600+)
VITE_HERO_STATS_FROM_BACKEND=false

# true = повний дебаг всіх API запитів у консолі браузера
VITE_DEBUG_API=false
