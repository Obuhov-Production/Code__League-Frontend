# ----------- Основні параметри -----------
VITE_APP_NAME=Code League
VITE_FRONTEND_PORT=4000

# ----------- Підключення до бекенду -----------
# URL бекенду (OAuth-редіректи, прямі виклики)
VITE_BACKEND_URL=http://localhost:4001

# Prefix для API запитів через Vite proxy — щоб не паритись з CORS під час розробки
VITE_API_BASE_URL=/api

# Якщо "false" — фронт працює без бекенду (мок-дані, без API запитів)
# Якщо "true"  — клієнт робить реальні запити до бекенду
VITE_CHECK_BACKEND=true

# ----------- Що нада тянуть с бека -----------

# Статистика на головній сторінці (блок info-stats)
# false → статичні заглушки | true → GET /api/stats
VITE_HERO_STATS_FROM_BACKEND=true

# Публічна сторінка лідерборду (/leaderboard)
# false → статичні mock-дані | true → GET /api/public/tournaments + /api/public/leaderboard/:id
VITE_LEADERBOARD_FROM_BACKEND=true

# ----------- Кантактікі :) -----------

# Метод відправки форми: Discord | Webhook | Telegram
# Детальніше: MyIdea/contact.md
CONTACT_METHOD=Discord

# ----------- логіка дебага для плотного воркінга -----------

# Логування всіх API запитів у консолі
# false → ніні (без логів) | true ( логі будуть ) → [PROXY] ➜ POST /api/auth/login → http://localhost:4001/api/auth/login
VITE_DEBUG_API=true
