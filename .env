# Прям база база (не трогай пж) 
# А ну і порт для хоста фронта
VITE_APP_NAME=Code League
VITE_FRONTEND_PORT=3000
# Backend URL (OAuth, direct calls)
VITE_BACKEND_URL=http://localhost:3001

 # Vite proxy prefix для API запитів (щоб не паритись з CORS під час розробки)
VITE_API_BASE_URL=/api

# Contact method: Discord, Webhook, Telegram!
# Поки не писав логіку на відправку цього Пропишу логіку на це в окремий фаіл MyIdea/contact.md
CONTACT_METHOD=Discord

# Штучка для того шоб я спокійно міг писати фронт не включив бекенд і не отримувати помилки в консолі про відсутність API.
# Якщо тут задано "false" -  Тоді ми не робимо запити до бекенду, а просто юзаєм фронт
# Якщо тут задано "true" -  Тоді Client буде робити API запити до бекенду і все працюватиме як треба по логіці!
VITE_CHECK_BACKEND=true

# Відображення реальних статистичних данних для блоку {info-stats} на головній сторінці.
# Якщо задано "false" -  Статичні цифри які прописані як заглушки і вони не будуть оновлюватись.
# Якщо задано "true" - Сатистичні данні будуть тянутись з бекенду і автоматично оновлюватимутся при кожному рендері.
VITE_HERO_STATS_FROM_BACKEND=false

# Повний дебав всіх API запитів для повного моніторінгу всіх запитів які відправляє клієнт на бекенд. та показує статус цих запитів.
# Якщо тут задано значення "true" - Тоді в консолі буде відображатись Debug значення типу [PROXY] ➜  POST /api/auth/login  →  http://localhost:3001/api/auth/login
# Якщо тут задано значення "false" - Тоді в консолі не буде відображатись жодного Debug значення про API запити до бекенду.
VITE_DEBUG_API=false
